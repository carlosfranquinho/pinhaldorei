<!DOCTYPE html>
<html lang="pt-PT" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
  {% if description %}<meta name="description" content="{{ description }}">{% endif %}
  <title>{{ title }} — Pinhal do Rei</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Crimson+Text:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.classless.min.css">
  <link rel="stylesheet" href="/assets/css/site.css">
</head>
<body class="{{ bodyClass | default('') }}">

  <header id="site-header">
    <nav>
      <ul>
        <li><a href="/" class="site-brand">Pinhal do Rei</a></li>
      </ul>
      <ul>
        {% for item in navigation.main %}
        <li><a href="{{ item.url }}">{{ item.title }}</a></li>
        {% endfor %}
      </ul>
      <ul>
        <li><button id="menu-toggle" class="outline secondary" aria-label="Menu">☰</button></li>
      </ul>
    </nav>
    <nav id="mobile-menu" hidden>
      <ul>
        {% for item in navigation.main %}
        <li><a href="{{ item.url }}">{{ item.title }}</a></li>
        {% endfor %}
      </ul>
    </nav>
  </header>

  {{ content | safe }}

  <footer>
    <div>
      <nav>
        <ul>
          {% for item in navigation.footer %}
          <li><a href="{{ item.url }}">{{ item.title }}</a></li>
          {% endfor %}
        </ul>
      </nav>
      <small>Pinhal do Rei</small>
    </div>
  </footer>

  <button id="scroll-top" aria-label="Voltar ao topo" title="Voltar ao topo">↑</button>
  <script src="/assets/js/site.js"></script>
</body>
</html>
